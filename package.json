{
  "name": "coverage-insights",
  "version": "0.3.9",
  "description": "Per-test coverage analysis for Vitest, Jest, and Gradle/JVM projects — find redundant tests, fragile lines, and coverage gaps.",
  "repository": {
    "type": "git",
    "url": "https://github.com/donovanh/coverage-insights.git"
  },
  "homepage": "https://github.com/donovanh/coverage-insights#readme",
  "keywords": [
    "coverage",
    "vitest",
    "jest",
    "gradle",
    "testing",
    "analysis",
    "istanbul"
  ],
  "bin": {
    "coverage-insights": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src tests --config eslint.config.mjs",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run build && npm test",
    "release:patch": "npm run build && npm test && npm version patch && npm publish",
    "release:minor": "npm run build && npm test && npm version minor && npm publish",
    "release:major": "npm run build && npm test && npm version major && npm publish"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7",
    "@babel/preset-env": "^7",
    "@babel/preset-typescript": "^7",
    "@eslint/js": "^9",
    "@types/jest": "^29",
    "@types/node": "^20.0.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "babel-jest": "^29",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "globals": "^15",
    "jest": "^29",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.8"
  }
}
